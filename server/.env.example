# Standard (non-SRV) connection string — use this format if your network
# blocks direct DNS SRV queries (common on mobile hotspot routers).
# Get the exact string from Atlas → Connect → Drivers → select pre-3.6 driver.
MONGODB_URI=mongodb://<user>:<password>@<shard-00-00>:27017,<shard-00-01>:27017,<shard-00-02>:27017/<dbname>?ssl=true&replicaSet=<replicaset-name>&authSource=admin&retryWrites=true&w=majority&appName=<cluster-name>

# Alternatively, if your network supports SRV lookups:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

JWT_SECRET=<random-32-char-string>
ADMIN_USERNAME=<admin-username>
ADMIN_PASSWORD=<min-8-char-password>
PORT=5001
